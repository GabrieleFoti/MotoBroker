---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { fotoMoto } from '../lib/foto';
import { formattaKm, formattaPrezzo } from '../lib/formatta';
import { slugMoto } from '../lib/moto';
import { url } from '../lib/url';

interface Props { entry: CollectionEntry<'moto'> }
const { entry } = Astro.props;
const slug = slugMoto(entry);
const copertina = fotoMoto(slug)[0];
const { marca, modello, anno, km, prezzo, venduta } = entry.data;
---
<a href={url(`/moto/${slug}/`)} class="moto-card">
  <div class="card-img">
    {copertina && <Image src={copertina} alt={`${marca} ${modello}`} width={640} widths={[320, 640]} sizes="(max-width: 640px) 100vw, 380px" />}
    <span class:list={['badge', { red: venduta }]}>{venduta ? 'Venduta' : 'Disponibile'}</span>
  </div>
  <div class="card-body">
    <h3>{marca} {modello}</h3>
    <div class="spec-row">
      <span>{anno}</span>
      {km !== undefined && <span>{formattaKm(km)}</span>}
    </div>
    <div class="card-foot">
      <strong class="price">{formattaPrezzo(prezzo)}</strong>
      <span class="open-link">Vedi scheda →</span>
    </div>
  </div>
</a>
<style>
  .moto-card {
    background: #121212;
    border: 1px solid #272727;
    border-radius: 24px;
    overflow: hidden;
    display: block;
    transition: 0.25s;
    position: relative;
  }
  .moto-card:hover {
    transform: translateY(-6px);
    border-color: #505050;
    box-shadow: 0 25px 55px rgba(0, 0, 0, 0.35);
  }
  .moto-card:focus-visible { outline: 3px solid var(--arancione); outline-offset: 4px; }
  .card-img { height: 265px; position: relative; background: #161616; overflow: hidden; }
  .card-img img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
  .moto-card:hover img { transform: scale(1.035); }
  .badge {
    position: absolute;
    top: 16px;
    left: 16px;
    border-radius: 999px;
    padding: 7px 10px;
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
  }
  .badge.red { background: rgba(225, 6, 0, 0.94); }
  .card-body { padding: 22px; }
  .card-body h3 {
    font-size: 1.8rem;
    font-family: var(--font-titoli);
    text-transform: uppercase;
    font-weight: 400;
    line-height: 1;
  }
  .spec-row { display: flex; gap: 13px; flex-wrap: wrap; color: #969696; font-size: 0.82rem; margin: 10px 0 20px; }
  .card-foot { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid #2b2b2b; padding-top: 17px; }
  .price { font-family: var(--font-titoli); font-size: 1.8rem; font-weight: 400; }
  .open-link { color: var(--arancione); font-weight: 900; font-size: 0.85rem; }
  @media (max-width: 650px) {
    .card-img { height: 245px; }
  }
</style>
