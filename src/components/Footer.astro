---
import { TELEFONO_DISPLAY, TELEFONO_TEL, linkWhatsApp } from '../lib/contatti';
---
<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-brand display">MOTO<span>BROKER.IT</span></div>
        <p>Conto vendita e intermediazione moto a Firenze e dintorni.</p>
      </div>
      <div>
        <h4>Contatti</h4>
        <p><a href={TELEFONO_TEL}>{TELEFONO_DISPLAY}</a></p>
        <p><a href={linkWhatsApp()}>WhatsApp</a></p>
      </div>
      <div>
        <h4>Servizi</h4>
        <p>Valutazione</p>
        <p>Foto e annunci</p>
        <p>Gestione trattativa</p>
      </div>
    </div>
    <div class="bottom">
      <span>© {new Date().getFullYear()} MotoBroker.it</span>
    </div>
  </div>
</footer>
<a class="whatsapp" href={linkWhatsApp()} aria-label="Apri WhatsApp">W</a>
<style>
  .footer { padding: 50px 0 28px; border-top: 1px solid #222; background: #090909; }
  .footer-grid { display: grid; grid-template-columns: 1.2fr 0.8fr 0.8fr; gap: 35px; }
  .footer-brand { font-size: 2.8rem; }
  .footer-brand span { color: var(--arancione); }
  .footer h4 { text-transform: uppercase; color: #777; font-size: 0.78rem; letter-spacing: 0.15em; }
  .footer p, .footer a { color: #aaa; font-size: 0.9rem; }
  .bottom { border-top: 1px solid #222; margin-top: 32px; padding-top: 20px; color: #666; font-size: 0.78rem; }
  .whatsapp {
    position: fixed;
    z-index: 60;
    right: 18px;
    bottom: 18px;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: #20c563;
    color: #fff;
    display: grid;
    place-items: center;
    font-size: 1.45rem;
    font-weight: 900;
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.42);
  }
  @media (max-width: 650px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
