---
import { getCollection } from 'astro:content';
import SchedaMoto from '../SchedaMoto.astro';
import { ordinaMoto } from '../../lib/moto';
import { url } from '../../lib/url';

const moto = ordinaMoto(await getCollection('moto')).slice(0, 3);
---
{moto.length > 0 && (
  <section class="section dark" id="moto">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow">Catalogo</div>
          <h2 class="display">Moto disponibili</h2>
        </div>
        <a class="btn btn-ghost" href={url('/moto/')}>Vedi tutte le moto</a>
      </div>
      <div class="grid">
        {moto.map((entry) => <SchedaMoto entry={entry} />)}
      </div>
    </div>
  </section>
)}
