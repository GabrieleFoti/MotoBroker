---
const servizi = [
  { n: '01', titolo: 'Valutazione professionale', testo: 'Analizziamo condizioni, mercato e posizionamento corretto della moto.' },
  { n: '02', titolo: 'Foto e annunci', testo: 'Presentazione curata e pubblicazione degli annunci sui canali più adatti.' },
  { n: '03', titolo: 'Trattativa gestita', testo: 'Gestiamo richieste, appuntamenti, trattativa, pagamento e consegna.' },
];
---
<section class="section" id="servizi">
  <div class="wrap">
    <div class="section-head">
      <div>
        <div class="eyebrow">Il nostro metodo</div>
        <h2 class="display">Ci occupiamo di tutto noi</h2>
      </div>
      <p>
        Valutiamo la moto, realizziamo foto e annunci, selezioniamo le persone seriamente
        interessate e gestiamo la trattativa fino alla vendita.
      </p>
    </div>
    <div class="grid">
      {servizi.map((s) => (
        <article class="servizio">
          <div class="eyebrow">{s.n}</div>
          <h3>{s.titolo}</h3>
          <p>{s.testo}</p>
        </article>
      ))}
    </div>
  </div>
</section>
<style>
  .servizio { background: #121212; border: 1px solid #272727; border-radius: 24px; padding: 22px; }
  .servizio h3 {
    font-size: 1.8rem;
    font-family: var(--font-titoli);
    text-transform: uppercase;
    font-weight: 400;
    line-height: 1;
    margin: 8px 0;
  }
  .servizio p { color: #999; }
</style>
