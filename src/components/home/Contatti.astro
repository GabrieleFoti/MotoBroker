---
import { TELEFONO_DISPLAY, linkWhatsApp } from '../../lib/contatti';

const wa = linkWhatsApp('Ciao MotoBroker.it, vorrei una valutazione della mia moto');
---
<section class="section dark" id="contatti">
  <div class="wrap">
    <div class="banner">
      <div class="eyebrow">Prima valutazione senza impegno</div>
      <h2 class="display">La tua moto merita il miglior risultato.</h2>
      <p>
        Mandaci marca, modello, anno, chilometri e alcune fotografie. Ti ricontatteremo per
        valutare il percorso più adatto.
      </p>
      <a class="btn banner-btn" href={wa}>Scrivici su WhatsApp · {TELEFONO_DISPLAY}</a>
    </div>
  </div>
</section>
<style>
  .banner {
    padding: 60px;
    border-radius: 30px;
    background: linear-gradient(135deg, #ad0500, #ef1e16);
    position: relative;
    overflow: hidden;
  }
  .banner .eyebrow { color: #fff; }
  .banner h2 { max-width: 750px; margin: 12px 0 18px; }
  .banner p { max-width: 600px; }
  .banner-btn { background: #fff; color: #111; margin-top: 15px; }
  @media (max-width: 650px) {
    .banner { padding: 35px 24px; }
  }
</style>
